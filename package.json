{
  "name": "duro-golpe",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace=backend run dev",
    "dev:frontend": "npm --workspace=frontend run dev",
    "typecheck:backend": "node ./node_modules/typescript/bin/tsc -p backend/tsconfig.json --noEmit",
    "typecheck:frontend": "node ./node_modules/typescript/bin/tsc -p frontend/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "infra:up": "docker compose up -d db cache",
    "db:migrate": "npm --workspace=backend run db:migrate",
    "beta:reset": "npm --workspace=backend run beta:reset --",
    "bootstrap": "npm run infra:up && npm run db:migrate && npm run seed:demo",
    "bootstrap:provider": "npm run infra:up && npm run db:migrate && npm --workspace=backend run seed",
    "bootstrap:hosted": "npm run db:migrate && npm run seed:demo",
    "bootstrap:hosted:provider": "npm run db:migrate && npm --workspace=backend run seed",
    "test:backend": "npm --workspace=backend run test",
    "test:launch-smoke": "node ./scripts/run-launch-smoke.mjs",
    "test:e2e": "npx playwright test",
    "seed": "npm --workspace=backend run seed",
    "seed:demo": "npm --workspace=backend run seed:demo",
    "sync:provider": "npm --workspace=backend run sync:provider",
    "sync:provider:repair": "npm --workspace=backend run sync:provider:repair",
    "match:override": "npm --workspace=backend run match:override --",
    "badges:backfill": "npm --workspace=backend run badges:backfill --",
    "audit:prod": "npm audit --omit=dev",
    "security:gate": "node ./scripts/check-prod-audit.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
