{
  "name": "duro-golpe-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --project integration",
    "seed": "tsx src/data-providers/seed-matches.ts",
    "seed:demo": "tsx src/dev/seed-demo.ts",
    "seed:smoke": "tsx src/dev/seed-smoke.ts",
    "sync:provider": "tsx src/data-providers/run-football-data-sync.ts",
    "sync:provider:repair": "tsx src/data-providers/run-football-data-sync-and-repair.ts",
    "beta:reset": "tsx src/dev/reset-beta.ts",
    "match:override": "tsx src/dev/override-match.ts",
    "teams:localize": "tsx src/dev/localize-teams.ts",
    "social-odds:backfill": "tsx src/dev/backfill-social-odds.ts",
    "smoke:lock-match": "tsx src/dev/lock-match.ts",
    "smoke:lock-outrights": "tsx src/dev/lock-outrights.ts",
    "outrights:resolve": "tsx src/outrights/resolve.ts",
    "outrights:enrich-player-media": "tsx src/outrights/enrich-player-media.ts",
    "badges:backfill": "tsx src/badges/backfill.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/oauth2": "^8.0.1",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.29.1",
    "eslint": "^9.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
