# Local development defaults. For hosted beta, use managed Neon/Upstash URLs.
DATABASE_URL=postgresql://duro_golpe:duro_golpe_dev@localhost:5432/duro_golpe
# Optional, but recommended for hosted Neon migrations. Use the direct, non-pooled URL when available.
DATABASE_MIGRATION_URL=
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars
# Optional for local demo and smoke. Required only for provider-backed `npm run seed`.
API_FOOTBALL_KEY=
WEBHOOK_SECRET=change-me-in-production-webhook-secret
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
# Optional until hosted OAuth is configured on the public domain.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
PORT=3001
NODE_ENV=development
