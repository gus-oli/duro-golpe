# Local development defaults. For local-tunnel private beta, keep managed Neon/Upstash URLs
# and set the public tunnel origin in BASE_URL / FRONTEND_URL.
DATABASE_URL=postgresql://duro_golpe:duro_golpe_dev@localhost:5432/duro_golpe
# Optional, but recommended for hosted Neon migrations. Use the direct, non-pooled URL when available.
DATABASE_MIGRATION_URL=
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars
# Optional API-Football key used only for legacy hooks and the manual player-photo enrichment script:
# `npm --workspace=backend run outrights:enrich-player-media`
API_FOOTBALL_KEY=
# Required for football-data.org provider-backed `npm run seed` / `npm run sync:provider`.
FOOTBALL_DATA_TOKEN=
# Enable the adaptive football-data.org poller inside the backend process.
FOOTBALL_DATA_POLL_ENABLED=false
# Optional override of the default World Cup provider target.
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026
WEBHOOK_SECRET=change-me-in-production-webhook-secret
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
# Optional for password recovery via Brevo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Duro Golpe
# Optional legacy/local OAuth path. Not part of the supported zero-cost hosted beta flow.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
BIND_HOST=127.0.0.1
PORT=3001
NODE_ENV=development
